# =============================================================================
# .env.example — Repod RPM Community Edition
# =============================================================================
# Copier en .env et adapter :
#   cp .env.example .env
# =============================================================================

# Adresse d'écoute (0.0.0.0 = toutes les interfaces, 127.0.0.1 = loopback only)
BIND_HOST=0.0.0.0

# Ports exposés sur l'hôte
RPM_PORT=8180
BACKEND_PORT=8100
FRONTEND_PORT=3103

# URL de l'API backend (vide = URLs relatives, le frontend proxifie via nginx)
# Surcharger si accès direct : REACT_APP_API_URL=http://IP:8100
REACT_APP_API_URL=

# URL publique du dépôt RPM (utilisée dans les fichiers .repo générés)
REACT_APP_REPO_URL=http://localhost:8180
