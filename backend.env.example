# =============================================================================
# backend.env.example — Repod RPM Community Edition
# =============================================================================
# Copier en backend.env et adapter :
#   cp backend.env.example backend.env
# Ne JAMAIS committer backend.env (déjà dans .gitignore).
#
# IMPORTANT : les `$` littéraux (ex : hash bcrypt) doivent être
# échappés en `$$` dans les fichiers env_file Docker Compose.
# =============================================================================

# -----------------------------------------------------------------------------
# JWT — Authentification
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_generate_with__python3_-c__import_secrets_print_secrets.token_hex_32

# Durée de vie des tokens en minutes (défaut : 60)
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Compte administrateur initial
# Créé automatiquement au premier démarrage si users.db est vide.
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin

# Hash bcrypt du mot de passe admin (défaut : Admin1234).
# ⚠️  Changez-le impérativement après le premier démarrage :
#     - Via le web UI : Profil → Changer le mot de passe
#     - Via l'API    : POST /auth/change-password
#
# Pour générer votre propre hash :
#   python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('VotreMotDePasse!'))"
# Remplacer chaque `$` par `$$` dans la valeur ci-dessous.
#
# Mot de passe par défaut : Admin1234
ADMIN_PASSWORD_HASH=$$2b$$12$$xJ2q6O8.nCZnTPJIKGYp1u6zFPgG5vMIbSSx01Cb4fXu4J3TWZ5vS

# -----------------------------------------------------------------------------
# CORS — Origines autorisées (séparées par des virgules)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3103

# -----------------------------------------------------------------------------
# Rate limiting sur les endpoints d'authentification (requêtes/minute par IP)
# -----------------------------------------------------------------------------
AUTH_RATELIMIT_PER_MINUTE=10

# -----------------------------------------------------------------------------
# Chemins internes (montés via volumes Docker — ne pas modifier sauf si vous
# changez les volumes dans docker-compose.yaml)
# -----------------------------------------------------------------------------
POOL_DIR=/repos/pool
MANIFEST_DIR=/repos/manifests
STAGING_INCOMING=/repos/staging/incoming
STAGING_QUARANTINE=/repos/staging/quarantine
AUDIT_DIR=/repos/audit
INDEX_PATH=/repos/manifests/index.json
INDEX_DIR=/repos/package-index
IMPORTS_DIR=/repos/imports
CLAMAV_DB_DIR=/var/lib/clamav
AUTH_DB_PATH=/repos/auth/users.db
SETTINGS_PATH=/repos/settings.json
SECURITY_DIR=/repos/security
NGINX_LOGS_DIR=/repos/logs
GNUPG_HOME=/repos/gnupg
REPO_BASE=/repos
